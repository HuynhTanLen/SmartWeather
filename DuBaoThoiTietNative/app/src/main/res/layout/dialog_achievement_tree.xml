<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardBackgroundColor="@android:color/transparent"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:id="@+id/dialogContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#E6121B22"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- Thay icon bằng Text emoji lớn cho mượt mà không cần chèn tài nguyên -->
        <TextView
            android:id="@+id/tvTreeEmoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="🌱"
            android:textSize="80sp" />

        <TextView
            android:id="@+id/tvDialogTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Nhiệm Vụ Hằng Ngày"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDialogDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:text="Hôm nay bạn chưa trồng thêm cây xanh nào. Trái Đất đang nóng lên từng ngày, hãy hành động nhé!"
            android:textColor="#B3FFFFFF"
            android:textSize="15sp"
            android:lineSpacingExtra="4dp" />

        <Button
            android:id="@+id/btnConfirmPlantDialog"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:backgroundTint="#4CAF50"
            android:text="Tôi Đã Trồng!"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="16dp" />

        <Button
            android:id="@+id/btnLater"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@android:color/transparent"
            android:text="Để tính sau"
            android:textAllCaps="false"
            android:textColor="#80FFFFFF"
            android:textSize="14sp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
